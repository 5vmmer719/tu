@startuml 出库管理模块类图
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam arrowFontSize 18
' ========== Controller 层 ==========
class OutOrderController {
  - outOrderService: OutOrderService
  + list(): AjaxResult
  + add(): AjaxResult
  + edit(): AjaxResult
  + remove(): AjaxResult
  + confirm(): AjaxResult
}

' ========== Service 层 ==========
interface OutOrderService {
  + selectOutOrderList(): List<StockOutOrder>
  + insertOutOrder(): int
  + updateOutOrder(): int
  + deleteOutOrder(): int
  + confirmOutOrder(): int
}

class OutOrderServiceImpl {
  - outOrderMapper: OutOrderMapper
  - labelService: MatLabelService
  - stockService: StockInfoService
  + selectOutOrderList(): List<StockOutOrder>
  + insertOutOrder(): int
  + updateOutOrder(): int
  + deleteOutOrder(): int
  + confirmOutOrder(): int
}

' ========== Entity 层 ==========
class StockOutOrder {
  - orderId: Long
  - orderNo: String
  - orderType: String
  - prodOrderNo: String
  - warehouseCode: String
  - workshopCode: String
  - orderStatus: String
  - warehouseKeeper: String
}

class StockOutDetail {
  - detailId: Long
  - orderNo: String
  - matCode: String
  - locationCode: String
  - planQuantity: BigDecimal
  - actualQuantity: BigDecimal
  - batchNo: String
}

class StockProdOrder {
  - prodOrderId: Long
  - prodOrderNo: String
  - prodMatCode: String
  - prodQuantity: BigDecimal
  - workshopCode: String
  - orderStatus: String
}

class StockMatLabel {
  - labelId: Long
  - matCode: String
  - usableQuantity: BigDecimal
  - receivedQuantity: BigDecimal
}

class BaseMat {
  - matId: Long
  - matCode: String
  - matName: String
}

class BaseWarehouse {
  - warehouseId: Long
  - warehouseCode: String
  - warehouseName: String
}

class BaseLocation {
  - locationId: Long
  - locationCode: String
  - locationName: String
}

class BaseWorkshop {
  - workshopId: Long
  - workshopCode: String
  - workshopName: String
}

' ========== 依赖关系 ==========
OutOrderController --> OutOrderService : 依赖
OutOrderService <|.. OutOrderServiceImpl : 实现
OutOrderServiceImpl ..> StockOutOrder : 操作
StockOutOrder --> StockProdOrder : 关联
StockOutOrder --> StockOutDetail : 包含
StockOutDetail --> StockMatLabel : 消耗
StockOutOrder --> BaseWarehouse : 关联
StockOutOrder --> BaseWorkshop : 关联
StockOutDetail --> BaseMat : 关联
StockOutDetail --> BaseLocation : 关联

@enduml

