@startuml 基础数据管理模块类图
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam arrowFontSize 18
' ========== Controller 层 ==========
class MatController {
  - matService: MatService
  + list(): AjaxResult
  + add(): AjaxResult
  + edit(): AjaxResult
  + remove(): AjaxResult
}

' ========== Service 层 ==========
interface MatService {
  + selectMatList(): List<BaseMat>
  + insertMat(): int
  + updateMat(): int
  + deleteMat(): int
}

class MatServiceImpl {
  - matMapper: MatMapper
  + selectMatList(): List<BaseMat>
  + insertMat(): int
  + updateMat(): int
  + deleteMat(): int
}

' ========== Entity 层 ==========
class BaseMat {
  - matId: Long
  - matCode: String
  - matName: String
  - figNum: String
  - matGroup: String
  - matClass: String
  - unit: String
  - safetyStock: BigDecimal
}

class BaseMatClass {
  - classId: Long
  - classCode: String
  - className: String
  - parentCode: String
  - orderNum: Integer
}

class BaseMatGroup {
  - groupId: Long
  - groupCode: String
  - groupName: String
  - remark: String
}

class BaseMatBom {
  - bomId: Long
  - parentMatCode: String
  - matCode: String
  - quantity: BigDecimal
}

class BaseWarehouse {
  - warehouseId: Long
  - warehouseCode: String
  - warehouseName: String
}

class BaseLocation {
  - locationId: Long
  - locationCode: String
  - locationName: String
  - warehouseCode: String
}

' ========== 依赖关系 ==========
MatController --> MatService : 依赖
MatService <|.. MatServiceImpl : 实现
MatServiceImpl ..> BaseMat : 操作
BaseMat --> BaseMatClass : 关联
BaseMat --> BaseMatGroup : 关联
BaseMat --> BaseMatBom : 关联
BaseLocation --> BaseWarehouse : 关联

@enduml

