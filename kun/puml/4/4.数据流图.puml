@startuml

start
:接收POST /stock/allotOrder请求;

:@PreAuthorize权限校验;
if (权限校验通过?) then (是)
else (否)
  :返回403错误响应;
  stop
endif

if (源仓库 == 目标仓库?) then (是)
  :返回error("仓库不能相同");
  stop
else (否)
endif

:调用stockAllotOrderService.insertStockAllotOrder();

partition "Service层处理 @Transactional" {
  :生成唯一调拨单号;
  :设置状态为待调拨、进度为未调出;
  :设置创建人和创建时间;

  if (调拨明细非空?) then (是)
    :遍历明细设置单号、仓库编码、行号;
    :批量插入调拨明细;
  else (否)
  endif

  :插入调拨单主表记录;
}

if (影响行数 > 0?) then (是)
  :返回AjaxResult.success;
else (否)
  :返回AjaxResult.error;
endif

stop

@enduml