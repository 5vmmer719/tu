@startuml
left to right direction
skinparam shadowing false
skinparam nodesep 10
skinparam ranksep 40

actor "管理员" as Admin

usecase "物料管理" as UC_Mat
usecase "仓库与货位管理" as UC_Wh
usecase "供应商管理" as UC_Sup
usecase "车间管理" as UC_Ws
usecase "用户与角色管理" as UC_User
usecase "菜单与权限配置" as UC_Menu
usecase "字典与参数配置" as UC_Dict
usecase "日志管理" as UC_Log
usecase "服务与缓存监控" as UC_Server
usecase "仪表盘" as UC_Dashboard
usecase "出入库统计" as UC_Stats

' --- 用例间关系 ---
UC_User ..> UC_Menu : <<include>>

' --- 管理员关联 ---
Admin --> UC_Mat
Admin --> UC_Wh
Admin --> UC_Sup
Admin --> UC_Ws
Admin --> UC_User
