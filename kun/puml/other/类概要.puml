@startuml
hide members
hide methods
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam nodesep 30
skinparam ranksep 80

' ========== 第1行：物料基础数据 ==========
class BaseMatClass
class BaseMat
class BaseMatBom
class BaseMatGroup

' ========== 第2行：仓储基础数据 ==========
class BaseWarehouse
class BaseSupplier
class BaseLocation
class BaseWorkshop

' ========== 第3行：入库 / 出库 / 调拨单据 ==========
class StockInOrder
class StockOutOrder
class StockAllotOrder

' ========== 第4行：关联单据 ==========
class StockInReturn
class StockOutReturn
class StockProdOrder

' ========== 第5行：库存数据 ==========
class StockMatLabel
class StockInfo
class StockRecord

' === 强制分层 ===
BaseMatClass -[hidden]down- BaseWarehouse
BaseWarehouse -[hidden]down- StockInOrder
StockInOrder -[hidden]down- StockInReturn
StockInReturn -[hidden]down- StockMatLabel

' === 同层对齐 ===
BaseMatClass -[hidden]right- BaseMat
BaseMat -[hidden]right- BaseMatBom
BaseMatBom -[hidden]right- BaseMatGroup

BaseWarehouse -[hidden]right- BaseSupplier
BaseSupplier -[hidden]right- BaseLocation
BaseLocation -[hidden]right- BaseWorkshop

StockInOrder -[hidden]right- StockOutOrder
StockOutOrder -[hidden]right- StockAllotOrder

StockInReturn -[hidden]right- StockOutReturn
StockOutReturn -[hidden]right- StockProdOrder

StockMatLabel -[hidden]right- StockInfo
StockInfo -[hidden]right- StockRecord

' --- 基础数据关联 ---
BaseMatBom --> BaseMat : 父子物料
BaseMatGroup ..> BaseMat : 物料组归属
BaseMatClass ..> BaseMat : 物料分类归属
BaseWarehouse --> BaseLocation : 包含货位

' --- 入库业务 ---
StockInOrder ..> BaseMat : 入库物料
StockInOrder ..> BaseWarehouse : 入库仓库
StockInOrder ..> BaseSupplier : 供应商
StockInOrder --> StockMatLabel : 生成标签
StockInReturn ..> StockInOrder : 关联入库单

' --- 出库业务 ---
StockProdOrder --> StockOutOrder : 生成出库单
StockOutOrder ..> BaseWarehouse : 出库仓库
StockOutOrder ..> BaseWorkshop : 领料车间
StockOutReturn ..> StockOutOrder : 关联出库单

' --- 调拨业务 ---
StockAllotOrder ..> StockOutOrder : 调拨出库
StockAllotOrder ..> StockInOrder : 调拨入库

' --- 库存与流水 ---
StockInfo ..> BaseMat : 库存物料
StockInfo ..> BaseWarehouse : 所在仓库
StockInfo --> StockRecord : 产生流水
StockMatLabel ..> BaseMat : 标签物料
StockRecord ..> StockMatLabel : 关联标签

@enduml