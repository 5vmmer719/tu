@startuml
left to right direction
skinparam shadowing false
skinparam nodesep 10
skinparam ranksep 40

actor "采购员" as Buyer

usecase "入库单管理" as UC_InOrder
usecase "入库质检" as UC_Check
usecase "入库退货" as UC_InReturn
usecase "物料标签管理" as UC_Label
usecase "生产订单管理" as UC_ProdOrder
usecase "领料出库" as UC_ProdOut
usecase "销售出库" as UC_ComOut
usecase "出库退货" as UC_OutReturn
usecase "调拨单管理" as UC_Allot
usecase "库存查询" as UC_Stock
usecase "库存流水查询" as UC_Record
usecase "统计分析" as UC_Stats

actor "仓管员" as Keeper
actor "计划员" as Planner

' --- 用例间关系 ---
UC_InOrder ..> UC_Check : <<include>>
UC_InOrder ..> UC_Label : <<include>>
UC_ProdOut ..> UC_ProdOrder : <<include>>

' --- 采购员（左侧） ---
Buyer --> UC_InOrder
Buyer --> UC_InReturn
Buyer --> UC_Label

' --- 仓管员（右侧） ---
UC_Check <-- Keeper
UC_InReturn <-- Keeper
UC_OutReturn <-- Keeper
UC_Allot <-- Keeper
UC_Stock <-- Keeper
UC_Record <-- Keeper

' --- 计划员（右侧） ---
UC_ProdOrder <-- Planner
UC_ProdOut <-- Planner
UC_ComOut <-- Planner
UC_Allot <-- Planner
UC_Stats <-- Planner

@enduml

