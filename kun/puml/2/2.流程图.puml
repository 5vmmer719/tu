@startuml

start
:仓管员扫描入库单二维码;

if (质检已通过且未入库?) then (是)
  :显示入库明细列表;
else (否)
  :提示状态异常;
  stop
endif

repeat
  :扫描物料标签，匹配入库明细;
  if (匹配成功?) then (是)
    :累加扫码数量;
  else (否)
    :提示标签错误;
  endif
repeat while (继续扫码?) is (是)
-> 否;

:确认提交，开启事务;

repeat
  :更新入库明细已入库数量;
  :更新库存（累加或新增）;
  :插入库存流水记录;
repeat while (还有未处理明细?) is (是)
-> 否;

:更新入库单状态为已入库;
:提交事务;
stop

@enduml