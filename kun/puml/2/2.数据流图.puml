@startuml

start
:接收POST /stock/inOrder/submitStockIn请求;

if (请求参数为空?) then (是)
  :返回error("系统繁忙");
  stop
else (否)
endif

:调用stockInOrderService.submitStockIn();

partition "Service层处理 @Transactional" {
  if (入库明细列表为空?) then (是)
    :返回AjaxResult.error;
    stop
  else (否)
  endif

  repeat
    :更新入库明细已入库数量;
    :查询库存记录;
    if (库存记录存在?) then (是)
      :累加库存数量;
    else (否)
      :新增库存记录;
    endif
    :插入库存流水记录;
  repeat while (还有未处理的明细?) is (是)
  -> 否;

  :更新入库单状态为已入库;

  if (调拨入库?) then (是)
    :更新关联调拨单进度;
  else (否)
  endif
}

:返回AjaxResult.success;
stop

@enduml