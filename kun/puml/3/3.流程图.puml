@startuml

start
:仓管员扫描出库单二维码;
:显示未完成出库明细列表;

repeat
  :扫描物料标签，匹配出库明细;
  if (匹配成功且货位、数量校验通过?) then (是)
    :累加扫码数量;
  else (否)
    :提示对应错误信息;
  endif
repeat while (继续扫码?) is (是)
-> 否;

:确认提交，开启事务;

repeat
  :校验并扣减库存;
  :更新出库明细已出库数量;
  :插入出库流水记录;
repeat while (还有未处理物料?) is (是)
-> 否;

if (所有明细已完成?) then (是)
  :状态设为已出库;
else (否)
  :状态设为部分出库;
endif

:提交事务;
stop

@enduml