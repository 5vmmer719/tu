@startuml 工艺与计划管理模块类图

scale 1000 width
top to bottom direction

skinparam classAttributeIconSize 0
skinparam classFontSize 18
skinparam classAttributeFontSize 16
skinparam linetype ortho
skinparam nodesep 30
skinparam ranksep 40
skinparam padding 2
skinparam arrowFontSize 18

' ========== Controller 层 ==========
class ProcessController <<Controller>> {
  - ProcessFacadeService processFacadeService
  + save(SaveProcessDTO): R<String>
  + update(UpdateProcessDTO): R<String>
  + delete(String): R<String>
  + page(PageProcessDTO): R<Page>
  + detail(String): R<DetailProcessVO>
}

' ========== Service 接口层 ==========
interface ProcessFacadeService <<Service>> {
  + saveProcess(SaveProcessDTO): void
  + getProcessDetail(String): DetailProcessVO
  + saveProcessRoute(SaveProcessRouteDTO): void
  + getMaterialProcessRoute(String): MaterialProcessRouteVO
}

interface ProductionOrderFacadeService <<Service>> {
  + save(SaveProductionOrderDTO): void
  + update(UpdateProductionOrderDTO): void
  + assignVin(String, String): String
}

' ========== Mapper 层 ==========
interface ProcessMapper <<Mapper>> {
  + selectById(String): ProcessPO
  + insert(ProcessPO): int
}

interface ProductionOrderMapper <<Mapper>> {
  + selectById(String): ProductionOrderPO
  + insert(ProductionOrderPO): int
}

' ========== Entity 层 ==========
class ProcessPO <<Entity>> {
  - String id
  - String code
  - String name
  - String workshopType
  - BigDecimal taktTime
  - ProcessRelationshipEnum processRelationship
}

class ProcessRoutePO <<Entity>> {
  - String id
  - String materialId
  - Graph<ProcessRouteNodePropertiesDTO> routeDesign
  - Boolean enabled
  - String vehicleModelCode
}

class ProductionOrderPO <<Entity>> {
  - String id
  - String code
  - String materialCode
  - BigDecimal quantity
  - LocalDateTime deliveryTime
  - Integer priority
  - OrderStatusEnum orderStatus
}

' ===== Controller → Service =====
ProcessController --> ProcessFacadeService

' ===== Service 间依赖 =====
ProcessFacadeService --> ProductionOrderFacadeService : 关联生产订单

' ===== Service → Mapper =====
ProcessFacadeService --> ProcessMapper
ProductionOrderFacadeService --> ProductionOrderMapper

' ===== Mapper → Entity =====
ProcessMapper ..> ProcessPO
ProductionOrderMapper ..> ProductionOrderPO

' ===== Entity 关联 =====
ProcessRoutePO ..> ProcessPO : 包含工序
ProductionOrderPO ..> ProcessRoutePO : 引用工艺路线

@enduml

