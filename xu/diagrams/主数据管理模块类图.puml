@startuml 主数据管理模块类图

scale 1000 width
top to bottom direction

skinparam classAttributeIconSize 0
skinparam classFontSize 18
skinparam classAttributeFontSize 16
skinparam linetype ortho
skinparam nodesep 30
skinparam ranksep 40
skinparam padding 2
skinparam arrowFontSize 18

' ========== Controller 层 ==========
class MaterialController <<Controller>> {
  - MaterialService service
  + save(SaveMaterialDTO): R<String>
  + update(UpdateMaterialDTO): R<String>
  + delete(String): R<String>
  + page(PageMaterialDTO): R<Page>
  + detail(String): R<DetailMaterialVO>
}

' ========== Service 接口层 ==========
interface MaterialService <<Service>> {
  + save(SaveMaterialDTO): void
  + update(UpdateMaterialDTO): void
  + page(PageMaterialDTO): Page
  + getDetail(String): DetailMaterialVO
  + existsCode(String): boolean
}

interface BomFacadeService <<Service>> {
  + saveManufactureBom(SaveManufactureBomDTO): void
  + getDetail(String): DetailManufactureBomVO
  + treeBom(String): Tree<MaterialBomVO>
}

' ========== Mapper 层 ==========
interface MaterialMapper <<Mapper>> {
  + selectById(String): MaterialPO
  + insert(MaterialPO): int
  + updateById(MaterialPO): int
}

interface ManufactureBomMapper <<Mapper>> {
  + selectById(String): ManufactureBomPO
  + insert(ManufactureBomPO): int
}

' ========== Entity 层 ==========
class MaterialPO <<Entity>> {
  - String id
  - String code
  - String name
  - MaterialTypeEnum type
  - MaterialSourceEnum source
  - BigDecimal quantity
  - BigDecimal safetyStock
  - String vehicleModelCode
}

class ManufactureBomPO <<Entity>> {
  - String id
  - String materialId
  - List<BomMaterialDTO> childMaterials
  - String parentBomId
  - Integer bomLevel
  - String bomPath
}

' ===== Controller → Service =====
MaterialController --> MaterialService

' ===== Service 间依赖 =====
MaterialService --> BomFacadeService : 关联BOM

' ===== Service → Mapper =====
MaterialService --> MaterialMapper
BomFacadeService --> ManufactureBomMapper

' ===== Mapper → Entity =====
MaterialMapper ..> MaterialPO
ManufactureBomMapper ..> ManufactureBomPO

' ===== Entity 关联 =====
ManufactureBomPO ..> MaterialPO : 引用物料

@enduml

