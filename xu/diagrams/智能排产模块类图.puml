@startuml 智能排产模块类图

scale 1000 width
top to bottom direction

skinparam classAttributeIconSize 0
skinparam classFontSize 18
skinparam classAttributeFontSize 16
skinparam linetype ortho
skinparam nodesep 30
skinparam ranksep 40
skinparam padding 2
skinparam arrowFontSize 18

' ========== Controller 层 ==========
class SmartSchedulingController <<Controller>> {
  - PlanningSmartService planningSmartService
  + generate(GeneratePlanningSmartDTO): R<String>
  + getPlanProgress(): R<PlanProgressVO>
  + cancel(): R<String>
  + confirm(): R<String>
}

' ========== Service 接口层 ==========
interface PlanningSmartService <<Service>> {
  + generate(GeneratePlanningSmartDTO): void
  + getPlanProgress(): PlanProgressVO
  + cancelPlanPending(): void
  + confirmPlan(): void
}

interface SolveService <<Service>> {
  + solve(UUID, PlanningStrategy, BasicData): void
  + existsSolving(): boolean
  + cancel(): void
}

interface PlanningStrategyService <<Service>> {
  + save(SavePlanningStrategyDTO): void
  + getDetail(String): DetailPlanningStrategyVO
  + updateActive(String, Boolean): void
}

' ========== Mapper 层 ==========
interface PlanInfoMapper <<Mapper>> {
  + selectById(String): PlanInfoPO
  + insert(PlanInfoPO): int
}

interface PlanTaskMapper <<Mapper>> {
  + selectById(String): PlanTaskPO
  + insert(PlanTaskPO): int
}

' ========== Entity 层 ==========
class PlanInfoPO <<Entity>> {
  - String id
  - LocalDateTime scheduleStartTime
  - LocalDateTime earliestTaskStartTime
  - PlanInfoStatusEnum planStatus
}

class PlanTaskPO <<Entity>> {
  - String id
  - String code
  - String mainResourceId
  - LocalDateTime startTime
  - LocalDateTime endTime
  - PlanTaskStatusEnum taskStatus
  - Boolean pinned
}

class PlanningStrategyPO <<Entity>> {
  - String id
  - String name
  - Boolean active
  - StrategyConfigDTO config
  - String vehicleModelCode
}

' ===== Controller → Service =====
SmartSchedulingController --> PlanningSmartService

' ===== Service 间依赖 =====
PlanningSmartService --> SolveService
PlanningSmartService --> PlanningStrategyService

' ===== SolveService → Mapper（求解过程读写排产数据） =====
SolveService --> PlanInfoMapper
SolveService --> PlanTaskMapper

' ===== Mapper → Entity =====
PlanInfoMapper ..> PlanInfoPO
PlanTaskMapper ..> PlanTaskPO

' ===== Entity 关联 =====
PlanInfoPO ..> PlanningStrategyPO : 引用策略
PlanTaskPO ..> PlanInfoPO : 关联计划

@enduml

