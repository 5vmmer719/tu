
@startuml
hide members
skinparam linetype ortho
skinparam nodesep 70
skinparam ranksep 90
skinparam arrowFontSize 20

entity "VEHICLE_MODEL" as VM
entity "MANUFACTURE_BOM" as BOM
entity "PROCESS_ROUTE" as PR
entity "PLANNING_STRATEGY" as PS
entity "MATERIAL" as MAT
entity "PROCESS" as PROC
entity "PRODUCTION_RESOURCE" as RES
entity "WORK_CALENDAR" as CAL
entity "WORK_MODE" as WM
entity "PRODUCTION_ORDER" as PO
entity "ORDER_BOM_ITEM" as OBI
entity "PLAN_INFO" as PI
entity "PLAN_TASK" as PT
entity "WORK_REPORT" as WR
entity "INCOMING_MATERIAL_ORDER" as IMO
entity "VEHICLE_CONFIGURATION" as VC

' === 布局控制 ===
VM -[hidden]down- BOM
BOM -[hidden]right- PR
PR -[hidden]right- PS

BOM -[hidden]down- MAT
MAT -[hidden]right- PROC
PROC -[hidden]right- RES
RES -[hidden]right- CAL
CAL -[hidden]right- WM

MAT -[hidden]down- PO
PO -[hidden]right- OBI
OBI -[hidden]right- PI
PI -[hidden]right- PT

PO -[hidden]down- WR
WR -[hidden]right- IMO
IMO -[hidden]right- VC

' --- 车型 ---
VM ||--down--|| BOM : 默认BOM
VM ||--down--o{ PR : 工艺路线
VM ||--down--o{ PS : 排产策略

' --- BOM与工艺 ---
BOM }o--down--|| MAT : 组成物料
PR }o--down--o{ PROC : 包含工序

' --- 工序 ---
PROC }o--right--o{ RES : 使用资源

' --- 资源与日历 ---
RES }o--right--o{ CAL : 遵循日历
CAL }o--right--|| WM : 工作模式

' --- 订单 ---
PO }o--up--|| MAT : 生产物料
PO ||--right--o{ OBI : 展开BOM
PO ||--down--|| VC : 车辆配置
OBI }o--up--|| MAT : 需求物料

' --- 计划 ---
PI ||--right--o{ PT : 包含任务
PT }o--up--|| PROC : 对应工序
PT }o--up--|| RES : 占用资源

' --- 执行反馈 ---
WR }o--up--|| PO : 反馈订单
WR }o--up--o| PT : 关联任务

' --- 辅助 ---
IMO }o--up--|| MAT : 采购物料
VC }o--up--|| VM : 属于车型

@enduml