@startuml
left to right direction
skinparam shadowing false

actor "系统用户" as User

usecase "排产策略配置" as UC_Strategy
usecase "智能调度" as UC_Schedule
usecase "任务分派" as UC_Assign
usecase "任务调整" as UC_Adjust
usecase "排产结果查看" as UC_ViewResult
usecase "Dashboard仪表盘" as UC_Dashboard

' 外部引用(来自工艺与计划管理模块)
usecase "生产订单管理" as UC_MO_Ref #LightGray

' 控制垂直排列顺序：策略在上，订单在下
UC_Strategy -[hidden]left- UC_Schedule
UC_Schedule -[hidden]up- UC_MO_Ref

' 用户与用例的关联
User --> UC_Strategy
User --> UC_Schedule
User --> UC_Assign
User --> UC_ViewResult
User --> UC_Dashboard

' 模块内用例关系
UC_Schedule ..> UC_Strategy : <<include>>
UC_Schedule ..> UC_MO_Ref : <<include>>
UC_Assign ..> UC_Schedule : <<include>>
UC_Adjust ..> UC_Assign : <<extend>>
UC_ViewResult ..> UC_Schedule : <<include>>

@enduml