@startuml

start
:接收POST /production-order请求;

partition "ProductionOrderFacadeServiceImpl.save  @Transactional" {
  :DTO转换为ProductionOrderPO;

  :查询数据库中是否存在相同订单号;
  if (订单号重复?) then (是)
    :抛出BusinessException;
    stop
  else (否)
  endif

  :业务规则校验\n（车型、VIN、物料编码）;
  :设置默认值\n（状态PENDING、优先级1等）;
  :插入订单数据;

  if (订单类型为整车?) then (是)
    :查询车型默认BOM;
    :遍历子件物料，计算需求量与缺口;
    :生成OrderBomItem与子订单;
    :批量插入子订单和BOM项;
  else (否)
  endif
}

:返回成功响应;
stop

@enduml